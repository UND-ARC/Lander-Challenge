- [lora_rx_0, out, blocks_message_debug_0, print]
- [lora_tx_0, '0', blocks_mute_xx_0, '0']
- [lora_tx_0, '0', iio_pluto_sink_0, '0']
- [lora_tx_0_0, '0', blocks_mute_xx_0_0, '0']

metadata:
  file_format: 1
